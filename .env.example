# Discord Bot Environment Variables

# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# ============================================
# AI Configuration (SIMPLE - Just Pick One!)
# ============================================

# Option 1: Ollama (LOCAL - NO API KEY NEEDED!)
# Install from: https://ollama.ai/download
# Run: ollama pull mistral
# Start: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Option 2: OpenAI (PREMIUM - Costs Money)
# Only if you want premium AI responses
# Get key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_key_here
# OPENAI_MODEL=gpt-4o-mini

# ============================================
# Advanced Extraction Config
# ============================================
EXTRACT_ROLE_ID=
EXPORT_LOG_CHANNEL_ID=
